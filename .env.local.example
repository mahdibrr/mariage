# Cloudflare R2 (dashboard.cloudflare.com → R2 → Manage R2 API Tokens → Create API Token)
# Access Key ID : string court affiché à la création du token
# Secret Access Key : string long (cfat_...) affiché à la création
CF_ACCOUNT_ID=your_account_id
CF_R2_BUCKET=your_bucket_name
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=cfat_your_secret_access_key

# App
NEXT_PUBLIC_WEDDING_COUPLE=هيثم وأميرة
NEXT_PUBLIC_WEDDING_DATE=30 يونيو 2026
NEXT_PUBLIC_APP_URL=http://localhost:3000
